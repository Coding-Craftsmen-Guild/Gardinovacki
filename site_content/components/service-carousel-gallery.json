{
  "componentType": "service-carousel-gallery",
  "description": "Inline horizontal carousel of images promoting a service (e.g., a few wedding photos with a 'see full gallery' button). Used on service pages (T3) and on the services landing (T2), and optionally on package detail pages (T6) to show example work.",
  "props": {
    "heading": { "type": "string", "required": false },
    "intro":   { "type": "string", "required": false },
    "images": {
      "type": "array",
      "required": true,
      "minItems": 1,
      "item": { "src": "string (URL)", "alt": "string" }
    },
    "cta": {
      "type": "object",
      "required": true,
      "shape": { "label": "string", "url": "string", "variant": "primary | secondary" },
      "note": "'See more' link to the full gallery page."
    }
  },
  "example": {
    "heading": "Venčanja",
    "intro": "Nekoliko nedavnih venčanja iz portfolija.",
    "images": [
