        { "label": "Paketi",   "url": "/paketi/" },
        { "label": "O meni",   "url": "/o-meni/" },
        { "label": "Kontakt",  "url": "/kontakt/" }
      ],
      "languageDropdown": {
        "current": "sr",
        "options": []
      },
      "socials": [
        { "platform": "facebook",  "url": "https://www.facebook.com/GardinovackiWeddings/",   "label": "Facebook"  },
        { "platform": "instagram", "url": "https://www.instagram.com/gardinovacki_weddings/", "label": "Instagram" },
        { "platform": "tiktok",    "url": "https://www.tiktok.com/@gardinovacki",             "label": "TikTok"    }
