  "contact-form-section": {
    "component": "contact-form-section",
    "props": {
      "backgroundImage": {
        "src": "https://gardinovacki.com/wp-content/uploads/2020/04/IMG_9655_1_1-scaled.jpg",
        "alt": "Mladenci u prirodi"
      },
      "heading": "Imate pitanje?",
      "intro": "Slobodno me pozovite ili pošaljite poruku — biće mi drago da čujem vašu priču.",
      "contactDetails": {
        "phone": "+381 60 5500858",
        "phoneHref": "tel:+381605500858",
        "email": "gardinovacki@hotmail.com",
        "emailHref": "mailto:gardinovacki@hotmail.com"
      },
      "form": {
        "action": "",
        "method": "post",
        "fields": [
          { "name": "name",     "label": "Ime",                 "type": "text",     "placeholder": "Ime",                 "required": true  },
          { "name": "email",    "label": "Email",               "type": "email",    "placeholder": "Email adresa",        "required": true  },
          { "name": "date",     "label": "Datum venčanja",      "type": "date",     "placeholder": "Datum venčanja",      "required": false },
          { "name": "location", "label": "Lokacija i mesto",    "type": "text",     "placeholder": "Lokacija i mesto",    "required": false },
          { "name": "package",  "label": "Paket",               "type": "select",   "required": false, "options": ["Family", "Platinum", "Gold", "Silver", "Mini"] },
          { "name": "message",  "label": "Dodatne informacije", "type": "textarea", "placeholder": "Dodatne informacije", "required": false }
        ],
        "submitLabel": "Pošalji"
      }
    }
  }
}
